{
  "name": "antd-boolean-select",
  "version": "1.0.1",
  "description": "An Ant Design Select wrapper for boolean values, with customizable true/false labels and configurable empty value behavior.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npx vite build && npx tsc -p tsconfig.json",
    "preview": "vite -c vite.config.preview.ts",
    "prepublishOnly": "npm run build",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "antd": ">=6.0.0"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "antd": "^6.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "license": "MIT",
  "author": "Czw96",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Czw96/antd-boolean-select.git"
  },
  "bugs": {
    "url": "https://github.com/Czw96/antd-boolean-select/issues"
  },
  "homepage": "https://github.com/Czw96/antd-boolean-select#readme",
  "keywords": [
    "react",
    "antd",
    "ant-design",
    "boolean",
    "select",
    "form",
    "typescript"
  ]
}
